  "dpo": {
    "epochs": 100,
    "learning_rate": 1e-5,
    "beta": 0.1,
    "special_tokens": ["<|user|>", "<|assistant|>", "<|end|>"]
  },
  "lora": {
    "epochs": 30,
    "batch_size": 64,
    "learning_rate": 1e-3,
    "rank": 4,
    "alpha": 8,
    "num_samples": 15000
  }
