{
  "pretrain": {
    "epochs": 100,
    "batch_size": 64,
    "learning_rate": 1e-3,
    "context_length": 64,
    "embed_dim": 128,
    "num_heads": 4,
    "ff_dim": 512,
    "num_blocks": 3,
    "dropout": 0.1,
    "num_samples": 50000,
    "max_vocab": 15000
  },
  "sft": {
    "epochs": 200,
